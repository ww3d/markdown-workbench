# Everything except the bundled extension, manifest, media and docs the
# Marketplace renders. node_modules is excluded because dist/extension.cjs
# is a self-contained bundle; the src/ sources are bundled into it. The
# media/webview.js and media/webview.css assets are NOT excluded: they run
# in the webview (not the host) and are loaded at runtime via asWebviewUri.
.github/**
docs/**
tests/**
bench/**
node_modules/**
src/**
build.ps1
publish.ps1
tsdown.config.ts
package-lock.json
.gitignore
.vscodeignore
*.vsix
coverage/**
# Exclude only the 256px design master; every other media/*.svg is a runtime
# asset (tab-action command icons, webview glyphs) that must ship in the vsix.
# This used to be an allowlist (exclude media/*.svg, re-add named files), but a
# forgotten negation silently dropped new icons from the package. Excluding the
# single source instead fails safe: at worst the package carries one file too
# many, never one too few. The Marketplace icon is media/icon.png.
media/icon.svg
